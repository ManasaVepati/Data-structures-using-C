#include <stdio.h>
#include <string.h>

int main() {
    int n;
    scanf("%d", &n);

    char str[n][100];

    // Input strings
    for(int i = 0; i < n; i++) {
        scanf("%s", str[i]);
    }

    int q;
    scanf("%d", &q);

    char query[100];

    for(int i = 0; i < q; i++) {
        scanf("%s", query);

        int count = 0;

        for(int j = 0; j < n; j++) {
            if(strcmp(query, str[j]) == 0) {
                count++;
            }
        }

        printf("%d\n", count);
    }

    return 0;
}
