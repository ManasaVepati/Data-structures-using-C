#include <stdio.h>

int birthdayCakeCandles(int candles_count, int* candles) {
    int max = candles[0];
    int count = 1;

    for (int i = 1; i < candles_count; i++) {
        if (candles[i] > max) {
            max = candles[i];
            count = 1;
        } else if (candles[i] == max) {
            count++;
        }
    }

    return count;
}

int main() {
    int n;
    scanf("%d", &n);

    int arr[n];

    for (int i = 0; i < n; i++) {
        scanf("%d", &arr[i]);
    }

    int result = birthdayCakeCandles(n, arr);

    printf("%d\n", result);

    return 0;
}
