#include <stdio.h>
#include <string.h>

int main() {
    char s[11];
    scanf("%s", s);

    int hour;
    sscanf(s, "%2d", &hour);

    if (s[8] == 'A') {
        if (hour == 12)
            hour = 0;
    } else {
        if (hour != 12)
            hour += 12;
    }

    printf("%02d:%c%c:%c%c\n",
           hour, s[3], s[4], s[6], s[7]);

    return 0;
}
