#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);

    for (int i = 0; i < n; i++) {
        int g;
        scanf("%d", &g);

        if (g >= 38) {
            int next = ((g / 5) + 1) * 5;

            if (next - g < 3) {
                g = next;
            }
        }

        printf("%d\n", g);
    }

    return 0;
}
