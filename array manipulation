#include <stdio.h>
#include <stdlib.h>

int main() {
    long n, q;
    scanf("%ld %ld", &n, &q);

    long *arr = (long*)calloc(n + 2, sizeof(long));

    for(int i = 0; i < q; i++) {
        long a, b, k;
        scanf("%ld %ld %ld", &a, &b, &k);

        arr[a] += k;
        arr[b + 1] -= k;
    }

    long max = 0, sum = 0;

    for(int i = 1; i <= n; i++) {
        sum += arr[i];
        if(sum > max) {
            max = sum;
        }
    }

    printf("%ld\n", max);

    free(arr);
    return 0;
}
