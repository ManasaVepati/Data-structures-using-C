#include <stdio.h>

int main() {
    int n;
    scanf("%d", &n);

    long long arr[n];   // use long long

    for (int i = 0; i < n; i++) {
        scanf("%lld", &arr[i]);   // %lld for long long
    }

    long long sum = 0;

    for (int i = 0; i < n; i++) {
        sum += arr[i];
    }

    printf("%lld\n", sum);   // print long long

    return 0;
}
